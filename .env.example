# Copy this file to .env and fill in real values. .env is gitignored.

# MongoDB connection string (Atlas SRV or local mongodb://...)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Base64-encoded HMAC secret for JWT signing. Must decode to >= 32 bytes for HS256.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-base64-encoded-hmac-secret
